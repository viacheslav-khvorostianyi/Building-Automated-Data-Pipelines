# ──────────────────────────────────────────────────────────────────────────────
# Environment variables for Airflow 3.0.0 Docker Compose (CeleryExecutor)
# Copy this file to .env and adjust values before running docker compose up
# ──────────────────────────────────────────────────────────────────────────────

# Your host user UID — prevents volume permission issues on Linux.
# Run `id -u` to find your UID.
AIRFLOW_UID=1000

# Directory that contains the airflow/ folder (dags, logs, plugins, config).
# Defaults to the current directory.
AIRFLOW_PROJ_DIR=.

# ── Admin user created on first `docker compose up` ───────────────────────────
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# ── Security — CHANGE THESE in production! ────────────────────────────────────
# Generate a Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=

# Generate a secret key: python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW__WEBSERVER__SECRET_KEY=airflow_secret

# Execution API JWT secret (Airflow 3.0 NEW).
# Used by worker task-runner subprocesses to authenticate to the API server.
# If unset, each container generates its OWN random key → 403 on every task.
# Must be identical on api-server AND all workers.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW__API_AUTH__JWT_SECRET=airflow_jwt_secret

# ── Optional: extra pip packages installed at container startup ───────────────
_PIP_ADDITIONAL_REQUIREMENTS=

WEATHER_API_KEY=97ad35a2e061558fbdfb2ae7144f1d75
